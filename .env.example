# ============================================
# AI爽文小说创作平台 - 环境变量配置示例
# ============================================
#
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 编辑 .env 文件，填入你的实际配置
# 3. 程序会自动读取这些环境变量
#

# ============================================
# NVIDIA NIM LLM API 配置（必需）
# ============================================

# NVIDIA NIM API Key（必需）
# 获取地址：https://build.nvidia.com/
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# NVIDIA NIM Base URL（可选，默认使用官方地址）
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# 默认使用的模型（可选）
# 可选模型：
# - meta/llama3-70b-instruct（推荐，高质量）
# - meta/llama3-8b-instruct（更快，便宜）
# - mistralai/mixtral-8x22b-instruct-v0.1
NVIDIA_NIM_MODEL=meta/llama3-70b-instruct

# ============================================
# 图像生成配置（可选）
# ============================================

# 本地Stable Diffusion模型路径（可选）
# 如果设置了，将使用本地模型而不是云端API
# LOCAL_SD_MODEL=/path/to/stable-diffusion-xl-base-1.0

# LoRA模型目录（可选）
# LORA_DIR=/path/to/lora/models

# ============================================
# TTS/音频配置（可选）
# ============================================

# 云端TTS API Key（可选，使用本地TTS时不需要）
# 支持：Azure TTS, ElevenLabs等
# TTS_API_KEY=your_tts_api_key

# Azure TTS区域（如果使用Azure）
# AZURE_REGION=eastasia

# ============================================
# 视频配置（可选）
# ============================================

# 默认视频分辨率（可选）
# 可选：720p, 1080p
# VIDEO_RESOLUTION=720p

# 输出视频比特率（可选）
# VIDEO_BITRATE=4000k

# ============================================
# 代理配置（如果需要）
# ============================================

# HTTP代理（如果需要翻墙访问API）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============================================
# 调试配置（开发用）
# ============================================

# 启用详细日志
# VERBOSE=true

# 启用Mock模式（不调用真实API，用于测试）
# MOCK_LLM=true

# ============================================
# 示例配置（可以直接复制使用）
# ============================================

# 开发/测试环境示例：
# NVIDIA_NIM_API_KEY=nvapi-xxxxxx
# MOCK_LLM=false
# VERBOSE=true

# 生产环境示例：
# NVIDIA_NIM_API_KEY=nvapi-xxxxxx
# NVIDIA_NIM_MODEL=meta/llama3-70b-instruct
# VIDEO_RESOLUTION=1080p
