{
  "_comment": "ComfyUI BGM 生成 Workflow - ACE-Step 1.5",
  "_note": "使用 ACE-Step 1.5 生成背景音乐",
  "_meta": {
    "description": "通过 ACE-Step 1.5 生成背景音乐，支持 tags 和 lyrics"
  },
  "1": {
    "inputs": {
      "unet_name": "acestep_v1.5_turbo.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {
      "title": "Load UNet (acestep)"
    }
  },
  "2": {
    "inputs": {
      "vae_name": "ace_1.5_vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {
      "title": "Load VAE (ace)"
    }
  },
  "3": {
    "inputs": {
      "clip_name1": "qwen_0.6b_ace15.safetensors",
      "clip_name2": "qwen_4b_ace15.safetensors",
      "type": "ace",
      "device": "default"
    },
    "class_type": "DualCLIPLoader",
    "_meta": {
      "title": "Load Dual CLIP (ace)"
    }
  },
  "4": {
    "inputs": {
      "seconds": 30,
      "batch_size": 1
    },
    "class_type": "EmptyAceStep1.5LatentAudio",
    "_meta": {
      "title": "Empty Audio Latent"
    }
  },
  "5": {
    "inputs": {
      "clip": ["3", 0],
      "tags": "Epic: A powerful, cinematic orchestral track with dramatic buildups and emotional crescendos.",
      "lyrics": "",
      "seed": 42,
      "bpm": 120,
      "duration": 30,
      "timesignature": "4",
      "language": "en",
      "keyscale": "C minor",
      "generate_audio_codes": true,
      "cfg_scale": 2,
      "temperature": 0.85,
      "top_p": 0.9,
      "top_k": 0,
      "min_p": 0
    },
    "class_type": "TextEncodeAceStepAudio1.5",
    "_meta": {
      "title": "Text Encode (tags/lyrics)"
    }
  },
  "6": {
    "inputs": {
      "conditioning": ["5", 0]
    },
    "class_type": "ConditioningZeroOut",
    "_meta": {
      "title": "Zero Out Negative"
    }
  },
  "7": {
    "inputs": {
      "model": ["1", 0],
      "shift": 3
    },
    "class_type": "ModelSamplingAuraFlow",
    "_meta": {
      "title": "Model Sampling"
    }
  },
  "8": {
    "inputs": {
      "model": ["7", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["4", 0],
      "seed": 42,
      "steps": 8,
      "cfg": 1,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler"
    }
  },
  "9": {
    "inputs": {
      "samples": ["8", 0],
      "vae": ["2", 0]
    },
    "class_type": "VAEDecodeAudio",
    "_meta": {
      "title": "VAE Decode Audio"
    }
  },
  "10": {
    "inputs": {
      "audio": ["9", 0],
      "filename_prefix": "audio/bgm",
      "quality": "V0"
    },
    "class_type": "SaveAudioMP3",
    "_meta": {
      "title": "Save Audio"
    }
  }
}