{
  "_comment": "ComfyUI Wan2.2 I2V Workflow - Fixed for API",
  "_meta": {
    "description": "Wan2.2 图生视频 workflow for API use",
    "default_size": {"width": 640, "height": 480},
    "default_frames": 81
  },
  "1": {
    "inputs": {"image": "input.png"},
    "class_type": "LoadImage",
    "_meta": {"title": "Load Image"}
  },
  "2": {
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "wan"
    },
    "class_type": "CLIPLoader",
    "_meta": {"title": "Load CLIP"}
  },
  "3": {
    "inputs": {"vae_name": "wan_2.1_vae.safetensors"},
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"}
  },
  "4": {
    "inputs": {
      "unet_name": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Load UNET high"}
  },
  "5": {
    "inputs": {
      "unet_name": "wan2.2_i2v_low_noise_14B_fp8_scaled.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Load UNET low"}
  },
  "6": {
    "inputs": {"model": ["4", 0], "shift": 5.0},
    "class_type": "ModelSamplingSD3",
    "_meta": {"title": "ModelSampling high"}
  },
  "7": {
    "inputs": {"model": ["5", 0], "shift": 5.0},
    "class_type": "ModelSamplingSD3",
    "_meta": {"title": "ModelSampling low"}
  },
  "8": {
    "inputs": {
      "clip": ["2", 0],
      "text": "The character stands still, camera slowly circles around."
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive prompt"}
  },
  "9": {
    "inputs": {
      "clip": ["2", 0],
      "text": "blurry, low quality, static, worst quality"
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative prompt"}
  },
  "10": {
    "inputs": {
      "positive": ["8", 0],
      "negative": ["9", 0],
      "vae": ["3", 0],
      "start_image": ["1", 0],
      "width": 640,
      "height": 480,
      "length": 81,
      "batch_size": 1
    },
    "class_type": "WanImageToVideo",
    "_meta": {"title": "WanImageToVideo"}
  },
  "11": {
    "inputs": {
      "model": ["6", 0],
      "positive": ["10", 0],
      "negative": ["10", 1],
      "latent_image": ["10", 2],
      "add_noise": "enable",
      "noise_seed": 42,
      "steps": 4,
      "cfg": 3.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "start_at_step": 0,
      "end_at_step": 2,
      "return_with_leftover_noise": "disable"
    },
    "class_type": "KSamplerAdvanced",
    "_meta": {"title": "KSampler high"}
  },
  "12": {
    "inputs": {
      "samples": ["11", 0],
      "vae": ["3", 0]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "13": {
    "inputs": {
      "images": ["12", 0],
      "fps": 24
    },
    "class_type": "CreateVideo",
    "_meta": {"title": "Create Video"}
  },
  "14": {
    "inputs": {
      "video": ["13", 0],
      "filename_prefix": "novel_video",
      "format": "mp4",
      "codec": "h264"
    },
    "class_type": "SaveVideo",
    "_meta": {"title": "Save Video"}
  }
}
